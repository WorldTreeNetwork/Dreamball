# Dreamball / jelly-server environment template.
# Copy to .env and fill in your values; .env is gitignored.

# ─── Embedding backend (priority order at boot) ──────────────────────────────
#
#   1. JELLY_EMBED_MOCK=1
#        Deterministic blake3-seeded mock. Use for CI, Storybook, unit tests.
#
#   2. RUNPOD_SERVERLESS_ENDPOINT_ID + RUNPOD_API_KEY
#        Remote RunPod Serverless GPU running Ollama qwen3-embedding:0.6b
#        (same worker image as the sibling Negotiated project).
#
#   3. JELLY_EMBED_MODEL_PATH (default: ./models/Qwen3-Embedding-0.6B-ONNX)
#        Local ONNX weights via @huggingface/transformers + onnxruntime-node.
#
#   4. None of the above → server boot fails fast.

# JELLY_EMBED_MOCK=1
# RUNPOD_API_KEY="rpa_..."
# RUNPOD_SERVERLESS_ENDPOINT_ID="..."
# JELLY_EMBED_RUNPOD_MODEL="qwen3-embedding:0.6b"
# JELLY_EMBED_MODEL_PATH="./models/Qwen3-Embedding-0.6B-ONNX"
